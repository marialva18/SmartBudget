# Server
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
TRUST_PROXY=false

# SQL Server / Prisma
# Replace these mock values in backend/.env only. Do not commit backend/.env.
DATABASE_URL="sqlserver://localhost:1433;database=SmartBudgetDb;user=smart_budget_user;password=change_me;encrypt=true;trustServerCertificate=true"

# Auth
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_COOKIE_MAX_AGE_MS=604800000

# AI providers
GEMINI_API_KEY=replace_only_if_gemini_is_enabled
