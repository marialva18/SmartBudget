generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                    @id(map: "PK_users") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  email                   String                    @unique(map: "UX_users_email") @db.NVarChar(320)
  passwordHash            String                    @map("password_hash") @db.NVarChar(255)
  status                  String                    @default("ACTIVE") @db.NVarChar(30)
  emailVerifiedAt         DateTime?                 @map("email_verified_at")
  createdAt               DateTime                  @default(now()) @map("created_at")
  updatedAt               DateTime                  @default(now()) @updatedAt @map("updated_at")
  lastLoginAt             DateTime?                 @map("last_login_at")
  deletedAt               DateTime?                 @map("deleted_at")
  accountChannelDefaults  AccountChannelDefault[]
  accounts                Account[]
  auditLogs               AuditLog[]
  budgets                 Budget[]
  categories              Category[]
  coachConversations      CoachConversation[]
  emailVerificationTokens EmailVerificationToken[]
  externalChannelLinks    ExternalChannelLink[]
  fileObjects             FileObject[]
  ownedGroups             FinancialGroup[]          @relation("GroupOwner")
  goalReservations        GoalReservation[]
  goals                   Goal[]
  createdGroupExpenses    GroupExpense[]            @relation("GroupExpenseCreator")
  groupMemberships        GroupMember[]
  createdGroupSettlements GroupSettlement[]         @relation("GroupSettlementCreator")
  passwordResetTokens     PasswordResetToken[]
  profile                 Profile?
  recurringOccurrences    RecurringOccurrence[]
  recurringSchedules      RecurringSchedule[]
  refreshTokens           RefreshToken[]
  transactionDrafts       TransactionDraft[]
  transactions            Transaction[]
  sessions                UserSession[]
  onboardingObjectives    UserOnboardingObjective[]
  voiceTranscriptions     VoiceTranscription[]

  @@map("users")
}

model Profile {
  id                  String   @id(map: "PK_profiles") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  userId              String   @unique(map: "UQ_profiles_user_id") @map("user_id") @db.UniqueIdentifier
  displayName         String   @map("display_name") @db.NVarChar(120)
  preferredCurrency   String   @default("PEN") @map("preferred_currency") @db.Char(3)
  timezone            String   @default("America/Lima") @db.NVarChar(80)
  theme               String   @default("SYSTEM") @db.NVarChar(20)
  aiEnabled           Boolean  @default(true) @map("ai_enabled")
  onboardingCompleted Boolean  @default(false) @map("onboarding_completed")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")
  user                User     @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "FK_profiles_users")

  @@map("profiles")
}

model UserOnboardingObjective {
  userId    String   @map("user_id") @db.UniqueIdentifier
  objective String   @db.NVarChar(40)
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "FK_user_onboarding_objectives_users")

  @@id([userId, objective], map: "PK_user_onboarding_objectives")
  @@map("user_onboarding_objectives")
}

model UserSession {
  id            String         @id(map: "PK_user_sessions") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  userId        String         @map("user_id") @db.UniqueIdentifier
  platform      String         @db.NVarChar(20)
  deviceName    String?        @map("device_name") @db.NVarChar(120)
  ipAddress     String?        @map("ip_address") @db.VarChar(45)
  userAgent     String?        @map("user_agent") @db.NVarChar(512)
  lastSeenAt    DateTime?      @map("last_seen_at")
  revokedAt     DateTime?      @map("revoked_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  refreshTokens RefreshToken[]
  user          User           @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "FK_user_sessions_users")

  @@index([userId, platform, createdAt(sort: Desc)], map: "IX_user_sessions_user_active")
  @@map("user_sessions")
}

model RefreshToken {
  id        String       @id(map: "PK_refresh_tokens") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  userId    String       @map("user_id") @db.UniqueIdentifier
  sessionId String?      @map("session_id") @db.UniqueIdentifier
  tokenHash String       @unique(map: "UX_refresh_tokens_token_hash") @map("token_hash") @db.NVarChar(255)
  expiresAt DateTime     @map("expires_at")
  revokedAt DateTime?    @map("revoked_at")
  createdAt DateTime     @default(now()) @map("created_at")
  session   UserSession? @relation(fields: [sessionId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_refresh_tokens_sessions")
  user      User         @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "FK_refresh_tokens_users")

  @@index([sessionId], map: "IX_refresh_tokens_session_id")
  @@index([userId, expiresAt], map: "IX_refresh_tokens_user_active")
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id(map: "PK_password_reset_tokens") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  userId    String    @map("user_id") @db.UniqueIdentifier
  tokenHash String    @unique(map: "UX_password_reset_tokens_token_hash") @map("token_hash") @db.NVarChar(255)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "FK_password_reset_tokens_users")

  @@index([userId, expiresAt], map: "IX_password_reset_tokens_user_active")
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id(map: "PK_email_verification_tokens") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  userId    String    @map("user_id") @db.UniqueIdentifier
  tokenHash String    @unique(map: "UX_email_verification_tokens_token_hash") @map("token_hash") @db.NVarChar(255)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "FK_email_verification_tokens_users")

  @@index([userId, expiresAt], map: "IX_email_verification_tokens_user_active")
  @@map("email_verification_tokens")
}

model Account {
  id                 String                  @id(map: "PK_accounts") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  userId             String                  @map("user_id") @db.UniqueIdentifier
  name               String                  @db.NVarChar(120)
  type               String                  @db.NVarChar(30)
  currency           String                  @db.Char(3)
  status             String                  @default("ACTIVE") @db.NVarChar(20)
  archivedAt         DateTime?               @map("archived_at")
  createdAt          DateTime                @default(now()) @map("created_at")
  updatedAt          DateTime                @default(now()) @updatedAt @map("updated_at")
  channelDefaults    AccountChannelDefault[]
  user               User                    @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "FK_accounts_users")
  goalReservations   GoalReservation[]
  recurringSchedules RecurringSchedule[]
  transactions       Transaction[]

  @@index([userId, status, currency, name], map: "IX_accounts_user_status")
  @@map("accounts")
}

model AccountChannelDefault {
  id        String   @id(map: "PK_account_channel_defaults") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  userId    String   @map("user_id") @db.UniqueIdentifier
  accountId String   @map("account_id") @db.UniqueIdentifier
  currency  String   @db.Char(3)
  channel   String   @db.NVarChar(20)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  account   Account  @relation(fields: [accountId], references: [id], onUpdate: NoAction, map: "FK_account_channel_defaults_accounts")
  user      User     @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "FK_account_channel_defaults_users")

  @@unique([userId, currency, channel], map: "UQ_account_channel_defaults")
  @@index([accountId], map: "IX_account_channel_defaults_account")
  @@map("account_channel_defaults")
}

model Category {
  id                 String              @id(map: "PK_categories") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  userId             String?             @map("user_id") @db.UniqueIdentifier
  name               String              @db.NVarChar(100)
  type               String              @db.NVarChar(20)
  icon               String?             @db.NVarChar(50)
  isSystem           Boolean             @default(false) @map("is_system")
  status             String              @default("ACTIVE") @db.NVarChar(20)
  archivedAt         DateTime?           @map("archived_at")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @default(now()) @updatedAt @map("updated_at")
  budgets            Budget[]
  user               User?               @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_categories_users")
  recurringSchedules RecurringSchedule[]
  transactions       Transaction[]

  @@index([userId, type, status], map: "IX_categories_user_status")
  @@map("categories")
}

model Transaction {
  id                   String                  @id(map: "PK_transactions") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  userId               String                  @map("user_id") @db.UniqueIdentifier
  accountId            String                  @map("account_id") @db.UniqueIdentifier
  categoryId           String?                 @map("category_id") @db.UniqueIdentifier
  type                 String                  @db.NVarChar(30)
  amount               Decimal                 @db.Decimal(19, 4)
  currency             String                  @db.Char(3)
  description          String?                 @db.NVarChar(250)
  occurredAt           DateTime                @map("occurred_at")
  source               String                  @db.NVarChar(30)
  idempotencyKey       String?                 @map("idempotency_key") @db.NVarChar(120)
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @default(now()) @updatedAt @map("updated_at")
  deletedAt            DateTime?               @map("deleted_at")
  groupExpenses        GroupExpense[]
  groupSettlements     GroupSettlement[]
  recurringOccurrences RecurringOccurrence[]
  attachments          TransactionAttachment[]
  transactionDrafts    TransactionDraft[]
  account              Account                 @relation(fields: [accountId], references: [id], onUpdate: NoAction, map: "FK_transactions_accounts")
  category             Category?               @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_transactions_categories")
  user                 User                    @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "FK_transactions_users")

  @@index([userId, occurredAt, type], map: "IX_transactions_calendar")
  @@index([userId, accountId, occurredAt(sort: Desc)], map: "IX_transactions_user_account_date")
  @@index([userId, categoryId, occurredAt(sort: Desc)], map: "IX_transactions_user_category_date")
  @@index([userId, occurredAt(sort: Desc)], map: "IX_transactions_user_occurred_active")
  @@map("transactions")
}

model Budget {
  id         String    @id(map: "PK_budgets") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  userId     String    @map("user_id") @db.UniqueIdentifier
  categoryId String?   @map("category_id") @db.UniqueIdentifier
  amount     Decimal   @db.Decimal(19, 4)
  currency   String    @db.Char(3)
  monthStart DateTime  @map("month_start") @db.Date
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at")
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_budgets_categories")
  user       User      @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "FK_budgets_users")

  @@index([userId, monthStart, currency], map: "IX_budgets_user_month")
  @@map("budgets")
}

model Goal {
  id                 String              @id(map: "PK_goals") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  userId             String              @map("user_id") @db.UniqueIdentifier
  name               String              @db.NVarChar(120)
  targetAmount       Decimal             @map("target_amount") @db.Decimal(19, 4)
  currency           String              @db.Char(3)
  targetDate         DateTime?           @map("target_date") @db.Date
  status             String              @default("ACTIVE") @db.NVarChar(20)
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @default(now()) @updatedAt @map("updated_at")
  completedAt        DateTime?           @map("completed_at")
  deletedAt          DateTime?           @map("deleted_at")
  reservations       GoalReservation[]
  user               User                @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "FK_goals_users")
  recurringSchedules RecurringSchedule[]

  @@index([userId, status, currency, targetDate], map: "IX_goals_user_status")
  @@map("goals")
}

model GoalReservation {
  id                   String                @id(map: "PK_goal_reservations") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  goalId               String                @map("goal_id") @db.UniqueIdentifier
  userId               String                @map("user_id") @db.UniqueIdentifier
  accountId            String                @map("account_id") @db.UniqueIdentifier
  amount               Decimal               @db.Decimal(19, 4)
  status               String                @default("ACTIVE") @db.NVarChar(20)
  source               String                @db.NVarChar(30)
  note                 String?               @db.NVarChar(250)
  reservedAt           DateTime              @map("reserved_at")
  insufficientAt       DateTime?             @map("insufficient_at")
  reversedAt           DateTime?             @map("reversed_at")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @default(now()) @updatedAt @map("updated_at")
  account              Account               @relation(fields: [accountId], references: [id], onUpdate: NoAction, map: "FK_goal_reservations_accounts")
  goal                 Goal                  @relation(fields: [goalId], references: [id], onUpdate: NoAction, map: "FK_goal_reservations_goals")
  user                 User                  @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "FK_goal_reservations_users")
  recurringOccurrences RecurringOccurrence[]

  @@index([accountId, status, reservedAt(sort: Desc)], map: "IX_goal_reservations_account_status")
  @@index([goalId, status, reservedAt(sort: Desc)], map: "IX_goal_reservations_goal_status")
  @@map("goal_reservations")
}

model RecurringSchedule {
  id            String                @id(map: "PK_recurring_schedules") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  userId        String                @map("user_id") @db.UniqueIdentifier
  accountId     String                @map("account_id") @db.UniqueIdentifier
  categoryId    String?               @map("category_id") @db.UniqueIdentifier
  goalId        String?               @map("goal_id") @db.UniqueIdentifier
  operationType String                @map("operation_type") @db.NVarChar(30)
  amount        Decimal               @db.Decimal(19, 4)
  currency      String                @db.Char(3)
  description   String?               @db.NVarChar(250)
  frequency     String                @db.NVarChar(20)
  intervalCount Int                   @default(1) @map("interval_count") @db.SmallInt
  startsOn      DateTime              @map("starts_on") @db.Date
  endsOn        DateTime?             @map("ends_on") @db.Date
  nextDueOn     DateTime              @map("next_due_on") @db.Date
  status        String                @default("ACTIVE") @db.NVarChar(20)
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @default(now()) @updatedAt @map("updated_at")
  occurrences   RecurringOccurrence[]
  account       Account               @relation(fields: [accountId], references: [id], onUpdate: NoAction, map: "FK_recurring_schedules_accounts")
  category      Category?             @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_recurring_schedules_categories")
  goal          Goal?                 @relation(fields: [goalId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_recurring_schedules_goals")
  user          User                  @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "FK_recurring_schedules_users")

  @@index([status, nextDueOn], map: "IX_recurring_schedules_due")
  @@index([userId, status, nextDueOn], map: "IX_recurring_schedules_user")
  @@map("recurring_schedules")
}

model RecurringOccurrence {
  id                String            @id(map: "PK_recurring_occurrences") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  scheduleId        String            @map("schedule_id") @db.UniqueIdentifier
  userId            String            @map("user_id") @db.UniqueIdentifier
  scheduledFor      DateTime          @map("scheduled_for") @db.Date
  status            String            @default("PENDING") @db.NVarChar(20)
  transactionId     String?           @map("transaction_id") @db.UniqueIdentifier
  goalReservationId String?           @map("goal_reservation_id") @db.UniqueIdentifier
  reviewedAt        DateTime?         @map("reviewed_at")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @default(now()) @updatedAt @map("updated_at")
  goalReservation   GoalReservation?  @relation(fields: [goalReservationId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_recurring_occurrences_reservations")
  schedule          RecurringSchedule @relation(fields: [scheduleId], references: [id], onUpdate: NoAction, map: "FK_recurring_occurrences_schedules")
  transaction       Transaction?      @relation(fields: [transactionId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_recurring_occurrences_transactions")
  user              User              @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "FK_recurring_occurrences_users")

  @@unique([scheduleId, scheduledFor], map: "UQ_recurring_occurrences_schedule_date")
  @@index([userId, scheduledFor], map: "IX_recurring_occurrences_user_pending")
  @@map("recurring_occurrences")
}

model FinancialGroup {
  id          String            @id(map: "PK_financial_groups") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  ownerId     String            @map("owner_id") @db.UniqueIdentifier
  name        String            @db.NVarChar(120)
  description String?           @db.NVarChar(500)
  status      String            @default("ACTIVE") @db.NVarChar(20)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @default(now()) @updatedAt @map("updated_at")
  archivedAt  DateTime?         @map("archived_at")
  owner       User              @relation("GroupOwner", fields: [ownerId], references: [id], onUpdate: NoAction, map: "FK_financial_groups_owner")
  expenses    GroupExpense[]
  members     GroupMember[]
  settlements GroupSettlement[]

  @@index([ownerId, status, createdAt(sort: Desc)], map: "IX_financial_groups_owner")
  @@map("financial_groups")
}

model GroupMember {
  id                  String              @id(map: "PK_group_members") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  groupId             String              @map("group_id") @db.UniqueIdentifier
  userId              String              @map("user_id") @db.UniqueIdentifier
  role                String              @db.NVarChar(20)
  status              String              @default("ACTIVE") @db.NVarChar(20)
  joinedAt            DateTime            @default(now()) @map("joined_at")
  leftAt              DateTime?           @map("left_at")
  expenseSplits       GroupExpenseSplit[]
  paidExpenses        GroupExpense[]      @relation("GroupExpensePayer")
  group               FinancialGroup      @relation(fields: [groupId], references: [id], onUpdate: NoAction, map: "FK_group_members_groups")
  user                User                @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "FK_group_members_users")
  outgoingSettlements GroupSettlement[]   @relation("SettlementFromMember")
  incomingSettlements GroupSettlement[]   @relation("SettlementToMember")

  @@unique([groupId, userId], map: "UQ_group_members_group_user")
  @@index([userId, status, groupId], map: "IX_group_members_user")
  @@map("group_members")
}

model GroupExpense {
  id                    String              @id(map: "PK_group_expenses") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  groupId               String              @map("group_id") @db.UniqueIdentifier
  paidByMemberId        String              @map("paid_by_member_id") @db.UniqueIdentifier
  createdByUserId       String              @map("created_by_user_id") @db.UniqueIdentifier
  personalTransactionId String?             @map("personal_transaction_id") @db.UniqueIdentifier
  description           String              @db.NVarChar(250)
  amount                Decimal             @db.Decimal(19, 4)
  currency              String              @db.Char(3)
  occurredAt            DateTime            @map("occurred_at")
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @default(now()) @updatedAt @map("updated_at")
  deletedAt             DateTime?           @map("deleted_at")
  splits                GroupExpenseSplit[]
  createdByUser         User                @relation("GroupExpenseCreator", fields: [createdByUserId], references: [id], onUpdate: NoAction, map: "FK_group_expenses_creator")
  group                 FinancialGroup      @relation(fields: [groupId], references: [id], onUpdate: NoAction, map: "FK_group_expenses_groups")
  paidByMember          GroupMember         @relation("GroupExpensePayer", fields: [paidByMemberId], references: [id], onUpdate: NoAction, map: "FK_group_expenses_payer")
  personalTransaction   Transaction?        @relation(fields: [personalTransactionId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_group_expenses_transaction")

  @@index([groupId, occurredAt(sort: Desc)], map: "IX_group_expenses_group_date")
  @@map("group_expenses")
}

model GroupExpenseSplit {
  id             String       @id(map: "PK_group_expense_splits") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  groupExpenseId String       @map("group_expense_id") @db.UniqueIdentifier
  memberId       String       @map("member_id") @db.UniqueIdentifier
  amount         Decimal      @db.Decimal(19, 4)
  createdAt      DateTime     @default(now()) @map("created_at")
  groupExpense   GroupExpense @relation(fields: [groupExpenseId], references: [id], onUpdate: NoAction, map: "FK_group_expense_splits_expenses")
  member         GroupMember  @relation(fields: [memberId], references: [id], onUpdate: NoAction, map: "FK_group_expense_splits_members")

  @@unique([groupExpenseId, memberId], map: "UQ_group_expense_splits_expense_member")
  @@index([memberId, groupExpenseId], map: "IX_group_expense_splits_member")
  @@map("group_expense_splits")
}

model GroupSettlement {
  id                    String         @id(map: "PK_group_settlements") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  groupId               String         @map("group_id") @db.UniqueIdentifier
  fromMemberId          String         @map("from_member_id") @db.UniqueIdentifier
  toMemberId            String         @map("to_member_id") @db.UniqueIdentifier
  createdByUserId       String         @map("created_by_user_id") @db.UniqueIdentifier
  personalTransactionId String?        @map("personal_transaction_id") @db.UniqueIdentifier
  amount                Decimal        @db.Decimal(19, 4)
  currency              String         @db.Char(3)
  settledAt             DateTime       @map("settled_at")
  note                  String?        @db.NVarChar(250)
  createdAt             DateTime       @default(now()) @map("created_at")
  deletedAt             DateTime?      @map("deleted_at")
  createdByUser         User           @relation("GroupSettlementCreator", fields: [createdByUserId], references: [id], onUpdate: NoAction, map: "FK_group_settlements_creator")
  fromMember            GroupMember    @relation("SettlementFromMember", fields: [fromMemberId], references: [id], onUpdate: NoAction, map: "FK_group_settlements_from_member")
  group                 FinancialGroup @relation(fields: [groupId], references: [id], onUpdate: NoAction, map: "FK_group_settlements_groups")
  toMember              GroupMember    @relation("SettlementToMember", fields: [toMemberId], references: [id], onUpdate: NoAction, map: "FK_group_settlements_to_member")
  personalTransaction   Transaction?   @relation(fields: [personalTransactionId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_group_settlements_transaction")

  @@index([groupId, settledAt(sort: Desc)], map: "IX_group_settlements_group_date")
  @@map("group_settlements")
}

model CoachConversation {
  id        String         @id(map: "PK_coach_conversations") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  userId    String         @map("user_id") @db.UniqueIdentifier
  title     String?        @db.NVarChar(160)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @default(now()) @updatedAt @map("updated_at")
  deletedAt DateTime?      @map("deleted_at")
  user      User           @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "FK_coach_conversations_users")
  messages  CoachMessage[]

  @@index([userId, updatedAt(sort: Desc)], map: "IX_coach_conversations_user_updated")
  @@map("coach_conversations")
}

model CoachMessage {
  id             String            @id(map: "PK_coach_messages") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  conversationId String            @map("conversation_id") @db.UniqueIdentifier
  role           String            @db.NVarChar(20)
  content        String            @db.NVarChar(Max)
  provider       String?           @db.NVarChar(60)
  model          String?           @db.NVarChar(80)
  tokenCount     Int?              @map("token_count")
  createdAt      DateTime          @default(now()) @map("created_at")
  deletedAt      DateTime?         @map("deleted_at")
  conversation   CoachConversation @relation(fields: [conversationId], references: [id], onUpdate: NoAction, map: "FK_coach_messages_conversations")

  @@index([conversationId, createdAt], map: "IX_coach_messages_conversation_created")
  @@map("coach_messages")
}

model ExternalChannelLink {
  id                 String    @id(map: "PK_external_channel_links") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  userId             String    @map("user_id") @db.UniqueIdentifier
  channelType        String    @map("channel_type") @db.NVarChar(30)
  externalIdentifier String    @map("external_identifier") @db.NVarChar(200)
  displayName        String?   @map("display_name") @db.NVarChar(120)
  status             String    @default("PENDING") @db.NVarChar(20)
  linkedAt           DateTime? @map("linked_at")
  revokedAt          DateTime? @map("revoked_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  user               User      @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "FK_external_channel_links_users")

  @@index([userId, channelType, status], map: "IX_external_channel_links_user")
  @@map("external_channel_links")
}

model TransactionDraft {
  id                   String       @id(map: "PK_transaction_drafts") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  userId               String       @map("user_id") @db.UniqueIdentifier
  source               String       @db.NVarChar(30)
  externalMessageId    String?      @map("external_message_id") @db.NVarChar(200)
  rawText              String?      @map("raw_text")
  parsedJson           String?      @map("parsed_json") @db.NVarChar(Max)
  confidence           Decimal?     @db.Decimal(5, 4)
  status               String       @default("PENDING") @db.NVarChar(30)
  expiresAt            DateTime     @map("expires_at")
  resolvedAt           DateTime?    @map("resolved_at")
  createdTransactionId String?      @map("created_transaction_id") @db.UniqueIdentifier
  createdAt            DateTime     @default(now()) @map("created_at")
  createdTransaction   Transaction? @relation(fields: [createdTransactionId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_transaction_drafts_transactions")
  user                 User         @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "FK_transaction_drafts_users")

  @@index([userId, expiresAt], map: "IX_transaction_drafts_user_pending")
  @@map("transaction_drafts")
}

model FileObject {
  id                    String                 @id(map: "PK_file_objects") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  userId                String                 @map("user_id") @db.UniqueIdentifier
  purpose               String                 @db.NVarChar(30)
  storageProvider       String                 @map("storage_provider") @db.NVarChar(30)
  objectKey             String                 @map("object_key") @db.NVarChar(500)
  originalName          String                 @map("original_name") @db.NVarChar(255)
  contentType           String                 @map("content_type") @db.NVarChar(120)
  sizeBytes             BigInt                 @map("size_bytes")
  checksumSha256        String?                @map("checksum_sha256") @db.Char(64)
  status                String                 @default("PENDING") @db.NVarChar(20)
  createdAt             DateTime               @default(now()) @map("created_at")
  availableAt           DateTime?              @map("available_at")
  deletedAt             DateTime?              @map("deleted_at")
  user                  User                   @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "FK_file_objects_users")
  transactionAttachment TransactionAttachment?
  voiceTranscriptions   VoiceTranscription[]

  @@unique([storageProvider, objectKey], map: "UX_file_objects_provider_key")
  @@index([userId, purpose, status, createdAt(sort: Desc)], map: "IX_file_objects_user_status")
  @@map("file_objects")
}

model TransactionAttachment {
  id            String      @id(map: "PK_transaction_attachments") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  transactionId String      @map("transaction_id") @db.UniqueIdentifier
  fileObjectId  String      @unique(map: "UQ_transaction_attachments_file") @map("file_object_id") @db.UniqueIdentifier
  createdAt     DateTime    @default(now()) @map("created_at")
  fileObject    FileObject  @relation(fields: [fileObjectId], references: [id], onUpdate: NoAction, map: "FK_transaction_attachments_files")
  transaction   Transaction @relation(fields: [transactionId], references: [id], onUpdate: NoAction, map: "FK_transaction_attachments_transactions")

  @@index([transactionId], map: "IX_transaction_attachments_transaction")
  @@map("transaction_attachments")
}

model VoiceTranscription {
  id              String      @id(map: "PK_voice_transcriptions") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  userId          String      @map("user_id") @db.UniqueIdentifier
  fileObjectId    String?     @map("file_object_id") @db.UniqueIdentifier
  source          String      @db.NVarChar(30)
  transcript      String      @db.NVarChar(2000)
  durationSeconds Int?        @map("duration_seconds")
  provider        String?     @db.NVarChar(60)
  confidence      Decimal?    @db.Decimal(5, 4)
  createdAt       DateTime    @default(now()) @map("created_at")
  deletedAt       DateTime?   @map("deleted_at")
  fileObject      FileObject? @relation(fields: [fileObjectId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_voice_transcriptions_files")
  user            User        @relation(fields: [userId], references: [id], onUpdate: NoAction, map: "FK_voice_transcriptions_users")

  @@index([userId, createdAt(sort: Desc)], map: "IX_voice_transcriptions_user_created")
  @@map("voice_transcriptions")
}

model AuditLog {
  id            String   @id(map: "PK_audit_logs") @default(dbgenerated("newsequentialid()")) @db.UniqueIdentifier
  userId        String?  @map("user_id") @db.UniqueIdentifier
  action        String   @db.NVarChar(100)
  entity        String   @db.NVarChar(100)
  entityId      String?  @map("entity_id") @db.UniqueIdentifier
  channel       String?  @db.NVarChar(30)
  requestId     String?  @map("request_id") @db.NVarChar(100)
  oldValuesJson String?  @map("old_values_json") @db.NVarChar(Max)
  newValuesJson String?  @map("new_values_json") @db.NVarChar(Max)
  metadataJson  String?  @map("metadata_json") @db.NVarChar(Max)
  ipAddress     String?  @map("ip_address") @db.VarChar(45)
  createdAt     DateTime @default(now()) @map("created_at")
  user          User?    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "FK_audit_logs_users")

  @@index([entity, entityId, createdAt(sort: Desc)], map: "IX_audit_logs_entity")
  @@index([requestId], map: "IX_audit_logs_request")
  @@index([userId, createdAt(sort: Desc)], map: "IX_audit_logs_user_created")
  @@map("audit_logs")
}
